generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  phone     String?
  role      String   @default("GUEST") // GUEST, HOST, ADMIN
  createdAt DateTime @default(now())

  listings Listing[]
  bookingsAsGuest Booking[] @relation("GuestBookings")
  bookingsAsHost  Booking[] @relation("HostBookings")
  reviews  Review[]
}

model Listing {
  id            String   @id @default(cuid())
  hostId        String
  title         String
  description   String
  type          String   @default("HOMESTAY") // HOMESTAY, HOTEL, APARTMENT, VILLA
  address       String
  city          String
  district      String?
  latitude      Float    @default(0)
  longitude     Float    @default(0)
  pricePerNight Int
  maxGuests     Int      @default(2)
  bedrooms      Int      @default(1)
  bathrooms     Int      @default(1)
  amenities     String   @default("[]") // JSON array
  images        String   @default("[]") // JSON array
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  host     User      @relation(fields: [hostId], references: [id])
  bookings Booking[]
  reviews  Review[]
}

model Booking {
  id          String   @id @default(cuid())
  listingId   String
  guestId     String
  hostId      String
  checkIn     DateTime
  checkOut    DateTime
  guests      Int      @default(1)
  totalNights Int
  totalPrice  Int
  status      String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  note        String?
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  guest   User    @relation("GuestBookings", fields: [guestId], references: [id])
  host    User    @relation("HostBookings", fields: [hostId], references: [id])
  review  Review?
}

model Review {
  id        String   @id @default(cuid())
  listingId String
  bookingId String   @unique
  guestId   String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])
  guest   User    @relation(fields: [guestId], references: [id])
}
